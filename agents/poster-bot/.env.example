# ═══════════════════════════════════════════════════
# Arena TaskPoster Bot Configuration
# ═══════════════════════════════════════════════════

# ── Blockchain Connection ──
RPC_URL=https://sepolia.base.org
PRIVATE_KEY=

# ── Arena Core ──
ARENA_CORE_ADDRESS=0x0E801D84Fa97b50751Dbf25036d067dCf18858bF
USDC_ADDRESS=0x99bbA657f2BbC93c02D617f8bA121cB8Fc104Acf

# ── Compliance (optional — set if ArenaCompliance is deployed) ──
COMPLIANCE_ADDRESS=

# ── IPFS (Pinata) ──
PINATA_API_KEY=
PINATA_SECRET=

# ── Task Posting ──
POST_INTERVAL_MS=600000
MIN_BOUNTY_USDC=100
MAX_BOUNTY_USDC=2500
MIN_BALANCE_USDC=500
DEADLINE_HOURS=24
SLASH_WINDOW_HOURS=168
BID_DURATION_SECONDS=3600
REVEAL_DURATION_SECONDS=1800
REQUIRED_VERIFIERS=3

# ── Task Mix (weights — higher = more likely) ──
WEIGHT_AUDIT=5
WEIGHT_RISK_VALIDATION=3
WEIGHT_CREDIT_SCORING=2

# ── Logging ──
LOG_LEVEL=info
DATA_DIR=./data
