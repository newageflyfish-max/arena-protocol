# ═══════════════════════════════════════════════════
# Arena VerifierAgent Configuration
# ═══════════════════════════════════════════════════

# ── Network ──
RPC_URL=https://sepolia.base.org
PRIVATE_KEY=your_private_key_here

# ── Contracts ──
ARENA_CORE_ADDRESS=0x0E801D84Fa97b50751Dbf25036d067dCf18858bF
USDC_ADDRESS=0x99bbA657f2BbC93c02D617f8bA121cB8Fc104Acf

# ── IPFS (Pinata) ──
PINATA_API_KEY=your_pinata_api_key
PINATA_SECRET=your_pinata_secret

# ── AI Analysis ──
ANTHROPIC_API_KEY=your_anthropic_api_key

# ── Verifier Pool ──
# Stake to deposit when joining the verifier pool (USDC)
POOL_STAKE_USDC=500
# Whether to auto-join the verifier pool on startup
AUTO_JOIN_POOL=true

# ── Verification Strategy ──
# Minimum match score (0-100) to approve. Below this, reject.
APPROVAL_THRESHOLD=70
# Auto-reject if agent missed critical/high findings we found
AUTO_REJECT_MISSED_CRITICAL=true
# Also auto-reject on missed high-severity findings (not just critical)
AUTO_REJECT_MISSED_HIGH=false
# Use comparison verification system when enabled on-chain
USE_COMPARISON_MODE=true

# ── Agent Behavior ──
# How often to poll for verification assignments (ms)
POLL_INTERVAL_MS=15000
# Directory for persisting verification state
DATA_DIR=./data
