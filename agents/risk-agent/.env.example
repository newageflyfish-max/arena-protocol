# ═══════════════════════════════════════════════════
# Arena RiskAgent Configuration
# ═══════════════════════════════════════════════════

# ── Network ──
RPC_URL=https://sepolia.base.org
PRIVATE_KEY=your_private_key_here

# ── Contracts ──
ARENA_CORE_ADDRESS=0x0E801D84Fa97b50751Dbf25036d067dCf18858bF
USDC_ADDRESS=0x99bbA657f2BbC93c02D617f8bA121cB8Fc104Acf

# ── IPFS (Pinata) ──
PINATA_API_KEY=your_pinata_api_key
PINATA_SECRET=your_pinata_secret

# ── External Data Sources ──
# DeFi Llama (free, no key needed)
DEFILLAMA_BASE_URL=https://api.llama.fi
# Coingecko (free tier or pro key)
COINGECKO_BASE_URL=https://api.coingecko.com/api/v3
COINGECKO_API_KEY=
# Additional RPC for on-chain reads (Ethereum mainnet)
MAINNET_RPC_URL=https://eth.llamarpc.com

# ── Bidding Strategy ──
MIN_BOUNTY_USDC=50
MAX_BID_USDC=3000
MAX_STAKE_PERCENT=15
RISK_TOLERANCE=medium

# ── Risk Model ──
# Which risk model to use: standard | conservative | defi_native
RISK_MODEL=standard
# Minimum confidence level to submit (0-1). Below this, skip delivery.
MIN_CONFIDENCE=0.5

# ── Agent Behavior ──
POLL_INTERVAL_MS=30000
DATA_DIR=./data
