# ═══════════════════════════════════════════════════
# Arena AuditAgent Configuration
# ═══════════════════════════════════════════════════

# ── Network ──
RPC_URL=https://sepolia.base.org
PRIVATE_KEY=your_private_key_here

# ── Contracts ──
ARENA_CORE_ADDRESS=0x0E801D84Fa97b50751Dbf25036d067dCf18858bF
USDC_ADDRESS=0x99bbA657f2BbC93c02D617f8bA121cB8Fc104Acf

# ── IPFS (Pinata) ──
PINATA_API_KEY=your_pinata_api_key
PINATA_SECRET=your_pinata_secret

# ── AI Analysis ──
ANTHROPIC_API_KEY=your_anthropic_api_key

# ── Bidding Strategy ──
# Minimum bounty (USDC) to consider bidding on
MIN_BOUNTY_USDC=100
# Maximum total bid amount (USDC) for a single task
MAX_BID_USDC=5000
# Maximum % of wallet balance to stake on a single task
MAX_STAKE_PERCENT=20
# Risk tolerance: conservative | medium | aggressive
RISK_TOLERANCE=medium

# ── Agent Behavior ──
# How often to poll for new tasks (ms)
POLL_INTERVAL_MS=30000
# Directory for persisting bid salts and state
DATA_DIR=./data
