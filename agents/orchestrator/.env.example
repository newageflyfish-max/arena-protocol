# ═══════════════════════════════════════════════════
# Arena AgentOrchestrator Configuration
# ═══════════════════════════════════════════════════

# ── Blockchain Connection ──
RPC_URL=https://sepolia.base.org
PRIVATE_KEY=

# ── Arena Core ──
ARENA_CORE_ADDRESS=0x0E801D84Fa97b50751Dbf25036d067dCf18858bF
USDC_ADDRESS=0x99bbA657f2BbC93c02D617f8bA121cB8Fc104Acf

# ── IPFS (Pinata) ──
PINATA_API_KEY=
PINATA_SECRET=

# ── AI (for audit + verifier agents) ──
ANTHROPIC_API_KEY=

# ── Data Sources (for risk agent) ──
DEFILLAMA_BASE_URL=https://api.llama.fi
COINGECKO_BASE_URL=https://api.coingecko.com/api/v3
COINGECKO_API_KEY=
MAINNET_RPC_URL=https://eth.llamarpc.com

# ── Agent Enable/Disable ──
ENABLE_AUDIT_AGENT=true
ENABLE_VERIFIER_AGENT=true
ENABLE_RISK_AGENT=true

# ── Bidding Defaults (shared across bidding agents) ──
MIN_BOUNTY_USDC=50
MAX_BID_USDC=5000
MAX_STAKE_PERCENT=20
RISK_TOLERANCE=medium

# ── Risk Agent Specific ──
RISK_MODEL=standard
MIN_CONFIDENCE=0.5

# ── Verifier Agent Specific ──
POOL_STAKE_USDC=500
AUTO_JOIN_POOL=true
APPROVAL_THRESHOLD=70
AUTO_REJECT_MISSED_CRITICAL=true
USE_COMPARISON_MODE=true

# ── Orchestrator ──
POLL_INTERVAL_MS=30000
DATA_DIR=./data
DASHBOARD_REFRESH_MS=2000
AUTO_RESTAKE=true
AUTO_RESTAKE_THRESHOLD_USDC=100
