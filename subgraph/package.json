{
  "name": "arena-subgraph",
  "version": "0.1.0",
  "description": "The Graph subgraph for The Arena protocol",
  "scripts": {
    "codegen": "graph codegen",
    "build": "graph build",
    "deploy": "graph deploy --node https://api.studio.thegraph.com/deploy/ arena-protocol/arena-core",
    "create-local": "graph create --node http://localhost:8020/ arena-protocol/arena-core",
    "remove-local": "graph remove --node http://localhost:8020/ arena-protocol/arena-core",
    "deploy-local": "graph deploy --node http://localhost:8020/ --ipfs http://localhost:5001 arena-protocol/arena-core"
  },
  "devDependencies": {
    "@graphprotocol/graph-cli": "^0.71.0",
    "@graphprotocol/graph-ts": "^0.32.0"
  }
}
